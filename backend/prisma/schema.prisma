generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Booking {
  id        String        @id
  userId    String
  serviceId String
  date      DateTime
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime
  Service   Service       @relation(fields: [serviceId], references: [id])
  User      User          @relation(fields: [userId], references: [id])
  Payment   Payment?

  @@schema("public")
}

model Category {
  id      String    @id
  name    String
  Product Product[]

  @@schema("public")
}

model Image {
  id          String    @id
  url         String
  type        ImageType
  productId   String?
  serviceId   String?
  portfolioId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Profile     Profile?  @relation(fields: [portfolioId], references: [id])
  Product     Product?  @relation(fields: [productId], references: [id])
  Service     Service?  @relation(fields: [serviceId], references: [id])

  @@schema("public")
}

model Order {
  id        String      @id
  userId    String
  total     Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  User      User        @relation(fields: [userId], references: [id])
  OrderItem OrderItem[]
  Payment   Payment?

  @@schema("public")
}

model OrderItem {
  id        String  @id
  orderId   String
  productId String
  quantity  Int
  price     Float
  Order     Order   @relation(fields: [orderId], references: [id])
  Product   Product @relation(fields: [productId], references: [id])

  @@schema("public")
}

model Payment {
  id            String        @id
  amount        Float
  status        PaymentStatus @default(PENDING)
  provider      String
  transactionId String?
  userId        String
  bookingId     String?       @unique
  orderId       String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Booking       Booking?      @relation(fields: [bookingId], references: [id])
  Order         Order?        @relation(fields: [orderId], references: [id])
  User          User          @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Product {
  id          String      @id
  name        String
  description String
  price       Float
  categoryId  String
  stock       Int
  sellerId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  Image       Image[]
  OrderItem   OrderItem[]
  Category    Category    @relation(fields: [categoryId], references: [id])
  User        User        @relation(fields: [sellerId], references: [id])
  Review      Review[]

  @@schema("public")
}

model Profile {
  id         String    @id
  userId     String    @unique
  firstName  String
  lastName   String
  phone      String?
  address    String?
  avatar     String?
  isProvider Boolean   @default(false)
  rating     Float?
  Image      Image[]
  User       User      @relation(fields: [userId], references: [id])
  Service    Service[]

  @@schema("public")
}

model Review {
  id        String   @id
  rating    Int
  comment   String?
  userId    String
  productId String?
  serviceId String?
  createdAt DateTime @default(now())
  Product   Product? @relation(fields: [productId], references: [id])
  Service   Service? @relation(fields: [serviceId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Service {
  id          String    @id
  name        String
  description String?
  price       Float
  duration    Int
  available   Boolean   @default(true)
  providerId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Booking     Booking[]
  Image       Image[]
  Review      Review[]
  Profile     Profile   @relation(fields: [providerId], references: [id])

  @@schema("public")
}

model User {
  id        String    @id
  email     String    @unique
  password  String
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Booking   Booking[]
  Order     Order[]
  Payment   Payment[]
  Product   Product[]
  Profile   Profile?
  Review    Review[]

  @@schema("public")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("public")
}

enum ImageType {
  UPLOADED
  URL

  @@schema("public")
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@schema("public")
}

enum Role {
  CLIENT
  COIFFEUSE
  VENDEUSE
  ADMIN

  @@schema("public")
}
